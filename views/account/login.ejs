<section class="account-login">
  <h1><%= title %></h1>

  <%- messages() %>

  <form action="/account/login" method="post" class="account-login__form">
    <label for="account_email">Email:</label>
    <input type="email" id="account_email" name="account_email">

    <label for="account_password">Password:</label>
    <input type="password" id="account_password" name="account_password">

    <button type="submit">Login</button>
  </form>

  <p class="account-login__signup">
    No account? <a href="/account/register" title="Go to sign-up page">Sign-up</a>
  </p>
</section>
<script src="/js/scripts.js"></script>
