<% if (errors) { %>
  <ul class="validation-errors">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<section class="account-management">
  <h1><%= title %></h1>

  <%- messages() %>

  <% if (accountData) { %>
    <h2>Welcome <%= accountData.account_firstname %></h2>
    <p>You're logged in.</p>
    <p>
      <a href="/account/update/<%= accountData.account_id %>" title="Update your account information">
        Edit Account Information
      </a>
    </p>

    <% if (accountData.account_type === "Employee" || accountData.account_type === "Admin") { %>
      <h3>Inventory Management</h3>
      <p><a href="/inv/" title="Go to the inventory management view">Manage Inventory</a></p>
    <% } %>
  <% } else { %>
    <p>Welcome.</p>
  <% } %>
</section>
