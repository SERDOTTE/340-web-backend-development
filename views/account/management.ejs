<% if (errors) { %>
  <ul class="validation-errors">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<section class="account-management">
  <h1><%= title %></h1>

  <%- messages() %>

  <% if (accountData) { %>
    <h2>Welcome <%= accountData.account_firstname %></h2>
    <p class="account-management__status">You're logged in.</p>

    <div class="account-management__actions">
      <a
        class="account-management__button-link"
        href="/account/update/<%= accountData.account_id %>"
        title="Update your account information"
      >
        Edit Account Information
      </a>

      <a
        class="account-management__button-link"
        href="/favorites/"
        title="View your saved favorite vehicles"
      >
        My Favorites
      </a>

      <% if (accountData.account_type === "Employee" || accountData.account_type === "Admin") { %>
        <a
          class="account-management__button-link"
          href="/inv/"
          title="Go to the inventory management view"
        >
          Manage Inventory
        </a>
      <% } %>
    </div>
  <% } else { %>
    <p>Welcome.</p>
  <% } %>
</section>
