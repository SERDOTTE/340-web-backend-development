<% if (errors) { %>
  <ul class="validation-errors">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<section class="account-management">
  <h1><%= title %></h1>

  <%- messages() %>

  <% if (accountData) { %>
    <p>Welcome <%= accountData.account_firstname %> <%= accountData.account_lastname %>.</p>
  <% } else { %>
    <p>Welcome.</p>
  <% } %>

  <p>You're logged in.</p>

  <% if (accountData && (accountData.account_type === "Employee" || accountData.account_type === "Admin")) { %>
    <h2>Inventory Management</h2>
    <p>Use the link below to manage inventory items.</p>
    <p><a href="/inv/" title="Go to the inventory management view">Manage Inventory</a></p>
  <% } %>
</section>
