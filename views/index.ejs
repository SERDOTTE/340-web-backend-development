<section class="home-content">
	<div class="home-hero">
		<h1>Welcome to CSE Motors!</h1>
		<%- messages() %>
		<div class="hero-overlay">
			<h2>DMC Delorean</h2>
			<ul>
				<li>3 Cup holders</li>
				<li>Superman doors</li>
				<li>Fuzzy dice</li>
			</ul>
			<a class="own-today" href="#">Own Today</a>
		</div>
	</div>

	<div class="home-reviews">
		<h2><strong>DMC Delorean Reviews</strong></h2>
		<ul>
			<li>"So fast it&apos;s almost like traveling in time." (4/5)</li>
			<li>"Coolest ride on the road." (4/5)</li>
			<li>"I&apos;m feeling McFly!" (5/5)</li>
			<li>"The most futurist ride of our day." (4/5)</li>
			<li>"80&apos;s livin and I love it!" (5/5)</li>
		</ul>
	</div>

	<div class="home-upgrades">
		<h2><strong>Delorean Upgrades</strong></h2>
		<div class="upgrades-grid">
			<div class="upgrade-item">
				<div class="upgrade-image-box">
					<img src="/images/upgrades/flux-cap.png" alt="Flux capacitor upgrade">
				</div>
				<a href="#">Flux Capacitor</a>
			</div>
			<div class="upgrade-item">
				<div class="upgrade-image-box">
					<img src="/images/upgrades/flame.jpg" alt="Flame decals upgrade">
				</div>
				<a href="#">Flame Decals</a>
			</div>
			<div class="upgrade-item">
				<div class="upgrade-image-box">
					<img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper sticker upgrade">
				</div>
				<a href="#">Bumper Stickers</a>
			</div>
			<div class="upgrade-item">
				<div class="upgrade-image-box">
					<img src="/images/upgrades/hub-cap.jpg" alt="Hub cap upgrade">
				</div>
				<a href="#">Hub Caps</a>
			</div>
		</div>
	</div>
</section>