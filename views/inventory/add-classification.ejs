<section class="inventory-form-page">
  <h1><%= title %></h1>
    <p class="inventory-form-page__note">FIELD IS REQUIRED.</p>
  <%- messages() %>

  <% if (errors) { %>
    <ul class="validation-errors">
      <% errors.array().forEach(error => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <form class="inventory-form" action="/inv/add-classification" method="post">
    <label for="classification_name">Classification Name</label>
    <p class="inventory-form-page__note">Name must be alphabetic characters only. No spaces or special characters are allowed.</p>
    <input
      type="text"
      id="classification_name"
      name="classification_name"
      pattern="^[A-Za-z0-9]+$"
      title="Use only letters and numbers. No spaces or special characters."
      required
      value="<%= locals.classification_name %>"
    >

    <button type="submit">Add Classification</button>
  </form>
</section>
