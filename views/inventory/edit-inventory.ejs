<section class="inventory-form-page">
  <h1><%= title %></h1>
  <p class="inventory-form-page__note">ALL FIELDS ARE REQUIRED.</p>
  <%- messages() %>

  <% if (errors) { %>
    <ul class="validation-errors">
      <% errors.array().forEach(error => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <form class="inventory-form" id="updateForm" action="/inv/update" method="post">
    <input type="hidden" name="inv_id" value="<%= locals.inv_id %>">

    <label for="classificationList">Classification</label>
    <p class="inventory-client-error" id="classificationList_error" aria-live="polite"></p>
    <%- classificationSelect %>

    <label for="inv_make">Make</label>
    <p class="inventory-client-error" id="inv_make_error" aria-live="polite"></p>
    <input type="text" id="inv_make" name="inv_make" placeholder="Min of 3 characters" minlength="3" required value="<%= locals.inv_make %>">

    <label for="inv_model">Model</label>
    <p class="inventory-client-error" id="inv_model_error" aria-live="polite"></p>
    <input type="text" id="inv_model" name="inv_model" placeholder="Min of 3 characters" minlength="3" required value="<%= locals.inv_model %>">

    <label for="inv_description">Description</label>
    <p class="inventory-client-error" id="inv_description_error" aria-live="polite"></p>
    <textarea id="inv_description" name="inv_description" rows="4" required><%= locals.inv_description %></textarea>

    <label for="inv_image">Image Path</label>
    <p class="inventory-client-error" id="inv_image_error" aria-live="polite"></p>
    <input type="text" id="inv_image" name="inv_image" required value="<%= locals.inv_image %>">

    <label for="inv_thumbnail">Thumbnail Path</label>
    <p class="inventory-client-error" id="inv_thumbnail_error" aria-live="polite"></p>
    <input type="text" id="inv_thumbnail" name="inv_thumbnail" required value="<%= locals.inv_thumbnail %>">

    <label for="inv_price">Price</label>
    <p class="inventory-client-error" id="inv_price_error" aria-live="polite"></p>
    <input type="text" id="inv_price" name="inv_price" inputmode="decimal" pattern="^\d+(\.\d{2})$" title="Use US format like 120.00 (dot as decimal separator)." placeholder="Example: 120.00" required value="<%= locals.inv_price %>">

    <label for="inv_year">Year</label>
    <p class="inventory-client-error" id="inv_year_error" aria-live="polite"></p>
    <input type="text" id="inv_year" name="inv_year" pattern="^\d{4}$" title="Use a 4-digit year." placeholder="4-digit year" required value="<%= locals.inv_year %>">

    <label for="inv_miles">Miles</label>
    <p class="inventory-client-error" id="inv_miles_error" aria-live="polite"></p>
    <input type="number" id="inv_miles" name="inv_miles" min="0" placeholder="digits only" required value="<%= locals.inv_miles %>">

    <label for="inv_color">Color</label>
    <p class="inventory-client-error" id="inv_color_error" aria-live="polite"></p>
    <input type="text" id="inv_color" name="inv_color" required value="<%= locals.inv_color %>">

    <button type="submit" disabled>Update Vehicle</button>
  </form>
</section>
<script src="/js/script.js"></script>
<script src="/js/inv-update.js"></script>
